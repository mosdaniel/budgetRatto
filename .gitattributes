# Normaliza saltos de línea automáticamente
* text=auto

# Fuerza LF para código fuente (consistencia entre Windows/Mac/Linux)
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.bat  text eol=crlf

# Binarios — sin conversión
*.png  binary
*.ico  binary
*.db   binary
*.zip  binary
